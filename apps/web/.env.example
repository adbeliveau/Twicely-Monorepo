# Database (ONLY hardcoded external dependency)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/twicely

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3000

# Tax ID encryption (SSN/EIN/ITIN stored in tax_info table)
ENCRYPTION_KEY=change-me-to-a-random-64-hex-string

# Provider secret encryption (Stripe, Shippo, etc. stored in provider_secret table)
PROVIDER_ENCRYPTION_KEY=change-me-to-a-different-64-hex-string

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_HUB_URL=http://localhost:3000

# Local transaction Ed25519 key pair (G2.7 dual-token QR)
# Generate with: npx tsx scripts/generate-local-tx-keys.ts
LOCAL_TX_SIGNING_KEY=
NEXT_PUBLIC_LOCAL_TX_VERIFY_KEY=

# Extension JWT (H1.1 — browser extension authentication)
# Must be at least 32 characters. Different from BETTER_AUTH_SECRET.
EXTENSION_JWT_SECRET=your-extension-jwt-secret-at-least-32-chars

# Cloudflare R2 Storage (Decision #23 — S3-compatible, uses @aws-sdk/client-s3)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=twicely-uploads
R2_PUBLIC_URL=https://assets.twicely.co

# SMS / Phone Verification (Decision #35 — provider abstraction)
SMS_PROVIDER=console
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=
TELNYX_MESSAGING_PROFILE_ID=

# Logging — Loki transport (optional, production only)
# Leave blank for development (logs go to console via pino-pretty)
LOKI_URL=
LOKI_BASIC_AUTH=

# Geocoding (Mapbox default, future: self-hosted Nominatim)
GEOCODING_PROVIDER=mapbox
MAPBOX_ACCESS_TOKEN=

# Cron job authorization (proxy.ts verifies via timing-safe comparison)
CRON_SECRET=change-me-to-a-random-32-char-string

# Stripe (test keys for development — production keys go in Railway/secrets manager)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=whsec_...
STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_...

# Email (Resend)
RESEND_API_KEY=re_...

# Valkey / Redis (cache + rate limiting + BullMQ)
VALKEY_URL=redis://localhost:6379
VALKEY_TOKEN=

# Typesense (full-text search)
TYPESENSE_URL=http://localhost:8108
TYPESENSE_API_KEY=
TYPESENSE_SEARCH_ONLY_KEY=

# Centrifugo (real-time WebSocket)
CENTRIFUGO_API_URL=http://localhost:8000/api
CENTRIFUGO_API_KEY=
CENTRIFUGO_TOKEN_HMAC_SECRET=

# Hub staff impersonation (HMAC-SHA256 token signing)
IMPERSONATION_SECRET=change-me-to-a-random-32-char-string

# Metrics endpoint auth
METRICS_SECRET=change-me-to-a-random-32-char-string

# S3-compatible endpoint override (for local MinIO dev)
S3_ENDPOINT=

# NOTE: All provider credentials (Shippo, push notifications, etc.) are stored
# encrypted in the database and configured through the admin UI at hub.twicely.co/cfg.
# The vars above are the minimum needed for a working local development environment.
