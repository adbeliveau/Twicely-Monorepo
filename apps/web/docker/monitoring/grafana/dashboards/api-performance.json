{
  "uid": "twicely-api-performance",
  "title": "Twicely API Performance",
  "description": "Request rate, latency by route, error rate by route",
  "tags": ["twicely", "api"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate by Route",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (route, method) (rate(twicely_http_requests_total[5m]))",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 Latency by Route",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (route, method, le) (rate(twicely_http_request_duration_seconds_bucket[10m])))",
          "legendFormat": "p95 {{method}} {{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate by Route",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (route) (rate(twicely_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx {{route}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Latency Heatmap",
      "type": "heatmap",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (le) (rate(twicely_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{le}}"
        }
      ]
    }
  ]
}
