{
  "name": "twicely",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --filter=@twicely/web --filter=@twicely/admin",
    "dev:mobile": "turbo run start --filter=@twicely/mobile",
    "build": "turbo run build --filter=@twicely/web --filter=@twicely/admin",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @twicely/web drizzle-kit generate",
    "db:push": "pnpm --filter @twicely/web drizzle-kit push",
    "db:seed": "pnpm --filter @twicely/db seed",
    "audit:deps": "pnpm audit --audit-level=high",
    "audit:security": "turbo run audit",
    "test:load": "k6 run tests/load/smoke.js",
    "test:load:full": "k6 run tests/load/full-suite.js"
  },
  "devDependencies": {
    "turbo": "^2.9.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "micromatch": ">=4.0.8",
      "braces": ">=3.0.3",
      "cookie": ">=0.7.0",
      "path-to-regexp": ">=6.3.0"
    }
  }
}
