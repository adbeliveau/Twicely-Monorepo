{
  "name": "twicely",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --filter=@twicely/web --filter=@twicely/admin",
    "dev:mobile": "turbo run start --filter=@twicely/mobile",
    "build": "turbo run build --filter=@twicely/web --filter=@twicely/admin",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @twicely/db drizzle-kit generate",
    "db:push": "pnpm --filter @twicely/db drizzle-kit push",
    "db:seed": "pnpm --filter @twicely/db seed"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
