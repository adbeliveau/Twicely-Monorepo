{
  "name": "@twicely/crosslister",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./automation/*": "./src/automation/*.ts",
    "./connectors/*": "./src/connectors/*.ts",
    "./handlers/*": "./src/handlers/*.ts",
    "./polling/*": "./src/polling/*.ts",
    "./queue/*": "./src/queue/*.ts",
    "./services/*": "./src/services/*.ts",
    "./workers/*": "./src/workers/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "bullmq": "^5.69.3",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.3.6",
    "@twicely/config": "workspace:*",
    "@twicely/db": "workspace:*",
    "@twicely/finance": "workspace:*",
    "@twicely/jobs": "workspace:*",
    "@twicely/logger": "workspace:*",
    "@twicely/notifications": "workspace:*",
    "@twicely/realtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20"
  }
}
